```{r, include=FALSE}
# Quadro de pessoal
pessoal_TJRO <- ipls_atual %>%
  filter(Ano == ano, str_detect(Mês_Ano, "Dez/")) %>%
  separate(Mês_Ano, c("Mes", "Ano"), remove = FALSE) %>%
  group_by(Ano, Indicador) %>%
  summarise(total = sum(Valor, na.rm = TRUE), .groups = "drop") %>%
  pivot_wider(names_from = Indicador, values_from = total) %>%
  mutate(Ano = as.numeric(Ano)) %>%
  mutate_at(vars(-Ano), ~coalesce(., 0)) %>%
  select(Ano, MagP, Serv, TPEfet, TPI, TPSV, TFAuxE,
