# Tabelas

casos_novos <-  jntj %>% 
                  filter(justica == 'Estadual', sigla == 'TJRO' , ano >= 2017 ) %>% 
                  select(justica, sigla, ano, cnocrim2, cnoncrim2, cnrcrim2 ,
                         cnrncrim2 , cnocrimtr , cnoncrimtr , cnrcrimtr , cnrncrimtr , cnccrim1, 
                         cncncrim1 , cnextfisc1 , cnextnfisc1 , 
                         exejudcrimnpl1 , exejudcrimpl1 , exejudncrim1 , 
                         cnccrimje , cncncrimje , cnextje , 
                         exejudcrimnplje , exejudncrimje) %>% 
                  mutate(casosnovos = (cnocrim2+ cnoncrim2 + cnrcrim2 +
                         cnrncrim2 + cnocrimtr + cnoncrimtr + cnrcrimtr + cnrncrimtr + cnccrim1+ 
                         cncncrim1 + cnextfisc1 + cnextnfisc1 + exejudcrimnpl1 + 
                         exejudcrimpl1 + exejudncrim1 + cnccrimje + cncncrimje + cnextje + 
                         exejudcrimnplje + exejudncrimje), ano = as.character(ano)) %>% 
                  select(Ano = ano, `Casos Novos` = casosnovos)

formattable(casos_novos)

# Gráfico
esquisse::esquisser()


