  spread(Indicador, total) %>% 
  select(Mes, AQV, PQV, PAS, AS, FTT) %>% 
  filter(!is.na(Mes)) %>%  
  mutate(
    PRQV = PQV / (FTT * AQV) * 100,  
    PRAS = PAS / (FTT * AS) * 100)

